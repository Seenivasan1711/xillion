# Replace example.com with your domain. Caddy auto-provisions TLS via Let's Encrypt.
# Install Caddy: https://caddyserver.com/docs/install

example.com {
    # Proxy everything to the backend (which serves both API and React SPA)
    reverse_proxy localhost:8000

    # Compress responses
    encode gzip

    # Security headers
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Frame-Options DENY
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    # Rate limit login/auth endpoints to reduce brute-force exposure
    # Requires caddy-ratelimit plugin; comment out if not installed
    # rate_limit {
    #     zone auth {
    #         match {
    #             path /api/auth/login /api/auth/setup
    #         }
    #         key {remote_host}
    #         events 10
    #         window 1m
    #     }
    # }

    log {
        output file /var/log/caddy/xillion.log
        format json
    }
}
