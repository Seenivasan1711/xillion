# =============================================================================
# Xillion — Environment Configuration
# Copy this to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# --- Application ---
APP_ENV=development                  # development | production
APP_PORT=8000
APP_BASE_URL=http://localhost:8000

# --- Database ---
# SQLite (default for local dev)
DATABASE_URL=sqlite+aiosqlite:///./data/xillion.db
# PostgreSQL (for production / Render)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/xillion

# --- Auth ---
APP_SECRET_KEY=change-me-to-a-long-random-hex-string
SESSION_LIFETIME_HOURS=8
ENCRYPTION_KEY=                      # Fernet key for encrypting TOTP secrets in DB
                                     # Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- Brokers ---
# Zerodha (Kite Connect) — leave empty until Phase 3
ZERODHA_PRIMARY_API_KEY=
ZERODHA_PRIMARY_API_SECRET=
ZERODHA_PRIMARY_USER_ID=
ZERODHA_PRIMARY_PASSWORD=
ZERODHA_PRIMARY_TOTP_SECRET=         # Base32 secret from Zerodha TOTP setup

# --- Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Compliance (SEBI) ---
APP_BIND_IP=                         # Static IP this app runs on; warns on mismatch
OPS_LIMIT_PER_SECOND=9               # Stay strictly under SEBI's 10/s retail threshold

# --- Risk defaults (per-strategy overrides these) ---
DEFAULT_ACCOUNT_DAILY_LOSS_PCT=3
DEFAULT_PER_STRATEGY_DAILY_LOSS_PCT=2
DEFAULT_MAX_OPEN_POSITIONS=10

# --- Plugin paths (relative to project root) ---
STRATEGIES_DIR=./strategies
BROKERS_DIR=./brokers
